---
import servicesData from '../data/services.json';

const { barbering, salon } = servicesData;
---

<section id="services" class="py-32 bg-[#366951]">
  <div class="container mx-auto px-6 max-w-7xl">
    <!-- Section Header -->
    <div class="text-center mb-24">
      <h2 class="font-display font-black text-[clamp(2.5rem,8vw,6rem)] leading-[0.9] tracking-tighter text-[#F4F3E7] mb-6 uppercase">
        Our Services
      </h2>
      <p class="text-xl text-[#F4F3E7] font-medium">
        Premium grooming tailored to your style
      </p>
    </div>

    <!-- Two-Card Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

      <!-- Barbering Card -->
      <div class="bg-[#F4F3E7] border-2 border-[#F4F3E7] p-10 md:p-12 hover:bg-[#2a5240] hover:text-[#F4F3E7] transition-all duration-300 group">
        <h3 class="font-display font-bold text-3xl md:text-4xl uppercase tracking-tight text-[#2a5240] group-hover:text-[#F4F3E7] mb-10">
          Barbering
        </h3>
        <ul class="space-y-8">
          {barbering.map((service) => (
            <li>
              <h4 class="font-display font-bold text-xl uppercase tracking-tight text-[#2a5240] group-hover:text-[#F4F3E7] mb-2">
                {service.name}
              </h4>
              <p class="text-[#2a5240]/70 group-hover:text-[#F4F3E7]/80 text-sm leading-relaxed">
                {service.description}
              </p>
            </li>
          ))}
        </ul>
      </div>

      <!-- Salon Services Card -->
      <div class="bg-[#F4F3E7] border-2 border-[#F4F3E7] p-10 md:p-12 hover:bg-[#2a5240] hover:text-[#F4F3E7] transition-all duration-300 group">
        <h3 class="font-display font-bold text-3xl md:text-4xl uppercase tracking-tight text-[#2a5240] group-hover:text-[#F4F3E7] mb-10">
          Salon Services
        </h3>
        <ul class="space-y-8">
          {salon.map((service) => (
            <li>
              <h4 class="font-display font-bold text-xl uppercase tracking-tight text-[#2a5240] group-hover:text-[#F4F3E7] mb-2">
                {service.name}
              </h4>
              <p class="text-[#2a5240]/70 group-hover:text-[#F4F3E7]/80 text-sm leading-relaxed">
                {service.description}
              </p>
            </li>
          ))}
        </ul>
      </div>

    </div>

    <!-- CTA -->
    <div class="mt-20 text-center">
      <p class="text-lg text-[#F4F3E7] mb-8 font-medium">
        Check with your barber or stylist for specific services and pricing.
      </p>
      <a
        href="#team"
        class="inline-block bg-[#2a5240] text-[#F4F3E7] px-12 py-5 text-lg font-bold uppercase tracking-wide hover:bg-[#1a3d2f] transition-colors"
      >
        Meet the Team
      </a>
    </div>
  </div>
</section>
